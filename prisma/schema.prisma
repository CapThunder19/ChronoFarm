generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  money     Int      @default(100)

  // Current region (for travel system)

  currentRegionId String?
  currentRegion   Region? @relation(fields: [currentRegionId], references: [id])

  farms     Farm[]
  inventory Inventory[]

  createdAt DateTime @default(now())
}

model Farm {
  id    String @id @default(cuid())
  level Int    @default(1)
  xp    Int    @default(0)

  userId String
  user   User @relation(fields: [userId], references: [id])

  // Associate a farm with a region so each region can have its own farm
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  crops Crop[]
  tiles Tile[]

  createdAt DateTime @default(now())

  @@unique([userId, regionId])
}

model Crop {
  id String @id @default(cuid())

  type String

  plantedAt DateTime
  readyAt   DateTime

  tileIndex Int

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])
}

model Inventory {
  id String @id @default(cuid())

  cropType String
  quantity Int @default(0)

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@unique([userId, cropType])
}

model Tile {
  id String @id @default(cuid())

  index Int
  unlocked Boolean @default(false)

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])

  @@unique([farmId, index])
}

model Timeline {
  id Int @id @default(1)

  year Int @default(1910)

  lastAdvanced DateTime @default(now())
}

model Region {
  id String @id @default(cuid())

  name String

  continent String

  description String

  // Region economic modifier

  priceMultiplier Float @default(1)

  // Active region (for single-player mode)

  isActive Boolean @default(false)
  // Level at which this region unlocks
  unlockLevel Int @default(1)

  users User[]
  farms Farm[]
  npcs NPC[]
  marketPrices MarketPrice[]

  createdAt DateTime @default(now())
}

model NPC {
  id String @id @default(cuid())

  name String

  regionId String
  region   Region @relation(fields: [regionId], references: [id])

  createdAt DateTime @default(now())
}

model MarketPrice {
  id String @id @default(cuid())

  cropType String

  // Stable base price

  basePrice Int

  // Current dynamic price

  price Int

  // Supply & demand system

  supply Int @default(100)
  demand Int @default(100)

  regionId String
  region   Region @relation(fields: [regionId], references: [id])

  updatedAt DateTime @updatedAt

  @@unique([cropType, regionId])
}

model MarketListing {
  id String @id @default(cuid())

  cropType String
  quantity Int
  price Int

  userId String

  createdAt DateTime @default(now())
}